datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ActivityType {
  ACTIVE
  IDLE
  MANUAL
  SYSTEM
}

enum ProductivityType {
  PRODUCTIVE
  NEUTRAL
  UNPRODUCTIVE
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  QA
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PayrollStatus {
  PAID
  UNPAID
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String
  role       Role      @default(EMPLOYEE)
  name       String?
  avatar     String?   @db.Text
  employee   Employee? @relation(fields: [employeeId], references: [id])
  employeeId String?   @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("users")
}

enum ComputerType {
  COMPANY
  PERSONAL
}

enum EmployeeStatus {
  INVITED
  ACTIVE
  OFFLINE
  IDLE
  DEACTIVATED
  MERGED
}

model Organization {
  id               String            @id @default(uuid())
  legalName        String
  workspaceId      String            @unique @default(uuid())
  industry         String?
  organizationSize String?
  timeZone         String            @default("UTC")
  workStartTime    String            @default("09:00")
  workEndTime      String            @default("18:00")
  workDays         String            @default("Monday,Tuesday,Wednesday,Thursday,Friday")
  teams            Team[]
  employees        Employee[]
  projects         Project[]
  tasks            Task[]
  activityLogs     ActivityLog[]
  screenshots      Screenshot[]
  appUsageLogs     AppUsageLog[]
  attendance       Attendance[]
  manualTimeEntries ManualTime[]
  shifts           Shift[]
  timeOffs         TimeOff[]
  complianceSetting ComplianceSetting?
  reportSetting    ReportSetting?
  locations        Location[]
  workZones        WorkZone[]
  locationLogs     LocationLog[]
  invoices         Invoice[]
  liveActivities   LiveActivity[]
  auditLogs        AuditLog[]
  alertRules       AlertRule[]
  alertSettings    AlertSettings?
  emailReports     EmailReport[]
  integrations     Integration[]
  productivityTags  ProductivityTag[]
  productivityRules ProductivityRule[]
  trackingSettings  TrackingSetting[]
  advancedTrackingSetting AdvancedTrackingSetting?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("organizations")
}

model Team {
  id             String       @id @default(uuid())
  name           String
  description    String?
  color          String?      @default("bg-blue-500")
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  employees      Employee[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("teams")
}

model Employee {
  id             String         @id @default(uuid())
  fullName       String
  email          String         @unique
  role           Role           @default(EMPLOYEE)
  location       String?        @default("Remote")
  computerType   ComputerType   @default(COMPANY)
  status         EmployeeStatus @default(ACTIVE)
  hourlyRate     Float          @default(0.0)
  avatar         String?        @db.Text
  user           User?
  team           Team?          @relation(fields: [teamId], references: [id])
  teamId         String?
  organization   Organization   @relation(fields: [organizationId], references: [id])
  organizationId String
  trackingSetting TrackingSetting? @relation(fields: [trackingSettingId], references: [id])
  trackingSettingId String?
  tasks          Task[]
  attendance     Attendance[]
  activityLogs   ActivityLog[]
  locationLogs   LocationLog[]
  payrollRecords PayrollRecord[]
  screenshots    Screenshot[]
  liveActivities LiveActivity[]
  appUsageLogs   AppUsageLog[]
  manualTimeEntries ManualTime[]
  shifts         Shift[]
  timeOffs       TimeOff[]
  projectAssignments ProjectAssignment[]
  projectTimeLogs    ProjectTimeLog[]
  auditLogs          AuditLog[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("employees")
}

model Project {
  id             String              @id @default(uuid())
  name           String
  billableRate   Float               @default(0.0)
  organization   Organization        @relation(fields: [organizationId], references: [id])
  organizationId String
  assignments    ProjectAssignment[]
  timeLogs       ProjectTimeLog[]
  tasks          Task[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("projects")
}

model ProjectAssignment {
  id         String   @id @default(uuid())
  project    Project  @relation(fields: [projectId], references: [id])
  projectId  String
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  createdAt  DateTime @default(now())

  @@unique([projectId, employeeId])
  @@map("project_assignments")
}

model ProjectTimeLog {
  id         String   @id @default(uuid())
  project    Project  @relation(fields: [projectId], references: [id])
  projectId  String
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  duration   Int      // in seconds
  type       String   // "CLOCKED" or "MANUAL"
  loggedAt   DateTime @default(now())

  @@map("project_time_logs")
}

model Task {
  id             String       @id @default(uuid())
  name           String
  status         TaskStatus   @default(BACKLOG)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  project        Project      @relation(fields: [projectId], references: [id])
  projectId      String
  employee       Employee?    @relation(fields: [employeeId], references: [id])
  employeeId     String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("tasks")
}

model Attendance {
  id             String       @id @default(uuid())
  date           DateTime     @db.Date
  clockIn        DateTime
  clockOut       DateTime?
  status         String       @default("PRESENT") // PRESENT, ABSENT, ON_LEAVE
  late           Boolean      @default(false)
  duration       Int          @default(0) // Duration in seconds
  employee       Employee     @relation(fields: [employeeId], references: [id])
  employeeId     String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("attendance")
}

model ManualTime {
  id             String       @id @default(uuid())
  startTime      DateTime
  endTime        DateTime
  timezone       String?
  type           String // e.g., "Work", "Meeting", "Break"
  duration       Int // in seconds
  note           String?      @db.Text
  employee       Employee     @relation(fields: [employeeId], references: [id])
  employeeId     String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("manual_time_entries")
}

model Shift {
  id             String       @id @default(uuid())
  startTime      String // e.g., "09:00"
  endTime        String // e.g., "18:00"
  date           DateTime     @db.Date
  employee       Employee     @relation(fields: [employeeId], references: [id])
  employeeId     String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("shifts")
}

model TimeOff {
  id             String       @id @default(uuid())
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  type           String       // "Days" | "Hours"
  timeOffType    String?      // "Sick Leave", "Annual Leave", etc.
  timezone       String?
  note           String?      @db.Text
  singleDay      Boolean      @default(false)
  employee       Employee     @relation(fields: [employeeId], references: [id])
  employeeId     String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("time_offs")
}

model ActivityLog {
  id             String           @id @default(uuid())
  activityType   ActivityType     @default(ACTIVE)
  productivity   ProductivityType @default(NEUTRAL)
  duration       Int              @default(0) // In seconds
  timestamp      DateTime         @default(now())
  appWebsite     String?          @default("Unknown")
  employee       Employee         @relation(fields: [employeeId], references: [id])
  employeeId     String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("activity_logs")
}

model LocationLog {
  id             String   @id @default(uuid())
  employeeId     String
  organizationId String
  latitude       Float
  longitude      Float
  accuracy       Float?
  source         String   @default("GPS")
  createdAt      DateTime @default(now())

  employee       Employee     @relation(fields: [employeeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@map("location_logs")
}

model WorkZone {
  id             String       @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  name           String
  type           String       @default("Office")
  latitude       Float
  longitude      Float
  radius         Float        @default(100.0) // In meters
  createdAt      DateTime     @default(now())

  @@map("work_zones")
}

model Location {
  id             String       @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  name           String
  type           String       @default("Office") // Office, Remote, Client
  address        String?
  latitude       Float?
  longitude      Float?
  threshold      Int          @default(4) // Default attendance threshold in hours
  createdAt      DateTime     @default(now())

  @@map("locations")
}

model ReportSetting {
  id                  String       @id @default(uuid())
  organization        Organization @relation(fields: [organizationId], references: [id])
  organizationId      String       @unique
  workloadOptimalFrom Int          @default(60)
  workloadOptimalTo   Int          @default(85)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@map("report_settings")
}

model PayrollRecord {
  id         String        @id @default(uuid())
  totalHours Float         @default(0.0)
  amount     Float         @default(0.0)
  status     PayrollStatus @default(UNPAID)
  employee   Employee      @relation(fields: [employeeId], references: [id])
  employeeId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("payroll_records")
}

model ComplianceSetting {
  id                String       @id @default(uuid())
  organization      Organization @relation(fields: [organizationId], references: [id])
  organizationId    String       @unique
  gdprEnabled       Boolean      @default(true)
  activityMonitoring Boolean      @default(true)
  locationTracking  Boolean      @default(true)
  showUrlsInActivityLogs Boolean  @default(false)
  blurLevel         Int          @default(2)
  saveOriginalScreenshots Boolean @default(false)
  collectPHI        Boolean?
  twoFactorEnabled  Boolean      @default(false)
  encryptionEnabled Boolean      @default(false)
  consentPercentage Float        @default(0.0)
  retentionPeriod   Int          @default(30) // In days
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@map("compliance_settings")
}

model AuditLog {
  id             String       @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  user           Employee     @relation(fields: [userId], references: [id])
  userId         String
  action         String
  status         String
  ipAddress      String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@map("audit_logs")
}

model Screenshot {
  id             String           @id @default(uuid())
  imageUrl       String           @db.LongText
  productivity   ProductivityType @default(NEUTRAL)
  blurred        Boolean          @default(false)
  capturedAt     DateTime         @default(now())
  employee       Employee         @relation(fields: [employeeId], references: [id])
  employeeId     String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("screenshots")
}

model AppUsageLog {
  id             String           @id @default(uuid())
  appName        String
  domain         String           @default("")
  category       String           @default("Uncategorized")
  productivity   ProductivityType @default(NEUTRAL)
  duration       Int              @default(0) // in seconds
  timestamp      DateTime         @default(now())
  employee       Employee         @relation(fields: [employeeId], references: [id])
  employeeId     String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime         @default(now())

  @@map("app_usage_logs")
}
model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  clientName     String
  clientEmail    String?
  amount         Float
  currency       String        @default("USD")
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  status         InvoiceStatus @default(DRAFT)
  notes          String?       @db.Text
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("invoices")
}

model LiveActivity {
  id             String   @id @default(uuid())
  employeeId     String
  organizationId String
  activeApp      String
  activeWindow   String
  keystrokes     Int
  mouseClicks    Int
  idleTime       Int
  createdAt      DateTime @default(now())

  employee     Employee     @relation(fields: [employeeId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("live_activities")
}

model InvitationToken {
  id             String   @id @default(uuid())
  email          String
  token          String   @unique
  organizationId String
  role           String
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@map("invitation_tokens")
}

model AlertRule {
  id             String       @id @default(uuid())
  name           String
  type           String       // "attendance", "security"
  trigger        String       // e.g., "Late", "No-show"
  scope          String       @default("All Employees")
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("alert_rules")
}

model AlertSettings {
  id                        String       @id @default(uuid())
  organization              Organization @relation(fields: [organizationId], references: [id])
  organizationId            String       @unique
  
  // Shift Scheduling
  earliestClockIn           Int          @default(15)
  latestClockOut            Int          @default(30)
  tolerance                 Int          @default(10)
  
  // Absent Notification
  absentInApp               Boolean      @default(true)
  absentEmail               Boolean      @default(false)
  
  // Headcount Notification
  headcountEnabled          Boolean      @default(true)
  headcountLateThreshold    Int          @default(15)
  headcountSendAfter        String       @default("scheduled_time")
  headcountInApp            Boolean      @default(true)
  headcountEmail            Boolean      @default(false)
  
  // Other
  productivityLabeling      String       @default("daily")
  manualTimeEntries         String       @default("daily")
  
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@map("alert_settings")
}

model EmailReport {
  id             String       @id @default(uuid())
  title          String
  frequency      String       // 'daily', 'weekly', 'monthly'
  recipients     Json         // Array of emails
  sendToSelf     Boolean      @default(true)
  content        Json         // Array of content options
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("email_reports")
}

model Integration {
  id             String       @id @default(uuid())
  integrationId  String       // 'csvImport', 'asana', 'bambooHR', etc.
  connected      Boolean      @default(false)
  config         Json         // API keys, connections strings, OAuth tokens, etc.
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, integrationId])
  @@map("integrations")
}

model ProductivityTag {
  id             String       @id @default(uuid())
  name           String
  color          String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  rules          ProductivityRule[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("productivity_tags")
}

model ProductivityRule {
  id             String           @id @default(uuid())
  appName        String?
  domain         String
  productivity   ProductivityType @default(NEUTRAL)
  category       String?          @default("Uncategorized")
  tag            ProductivityTag? @relation(fields: [tagId], references: [id])
  tagId          String?
  organization   Organization     @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, domain])
  @@map("productivity_rules")
}

model TrackingSetting {
  id                     String           @id @default(uuid())
  title                  String
  computerType           String           // 'company' | 'personal'
  isDefault              Boolean          @default(false)
  visibility             String           @default("visible") // 'visible' | 'stealth'
  screenshotsPerHour     Int              @default(0)
  allowAccessScreenshots Boolean          @default(false)
  allowRemoveScreenshots Boolean          @default(false)
  breakTime              Int              @default(0)
  allowOverBreak         Boolean          @default(false)
  allowNewBreaks         Boolean          @default(false)
  idleTime               Int              @default(2)
  trackingScenario       String           @default("unlimited")
  workingDays            Json             // Array of days
  trackTasks             Boolean          @default(false)
  allowAddTasks          Boolean          @default(false)
  permissions            Json             // canAnalyze, canSeeApps, canAddManual
  organization           Organization     @relation(fields: [organizationId], references: [id])
  organizationId         String
  employees              Employee[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@map("tracking_settings")
}

model AdvancedTrackingSetting {
  id                  String       @id @default(uuid())
  shiftThreshold      Int          @default(4)
  strictTime          Boolean      @default(false)
  inactivityPopups    Boolean      @default(true)
  identificationMode  String       @default("hwid")
  showEngagement      Boolean      @default(false)
  useActiveDirectory  Boolean      @default(true)
  adEmail             Boolean      @default(true)
  adTeam              Boolean      @default(true)
  adTrackingSettings  Boolean      @default(false)
  organization        Organization @relation(fields: [organizationId], references: [id])
  organizationId      String       @unique
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@map("advanced_tracking_settings")
}
